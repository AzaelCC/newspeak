# Copy this file to .env and uncomment the lines you want to change.
# All settings have sensible defaults; you only need to set what differs.
#
# Nested keys use double-underscore as separator (SECTION__KEY).
# Environment variables take precedence over .env values.

# --- Server ---
# SERVER__PORT=8000
# SERVER__LLAMA_SERVER_URL=http://localhost:8001
# SERVER__LLAMA_MODEL=gemma-4-E2B-it
# SERVER__LOG_LEVEL=INFO

# --- Audio pipeline ---
# "direct"   — sends raw WAV audio to the chat model (default)
# "whisperx" — transcribes locally with WhisperX, then sends text
# AUDIO__PIPELINE=direct

# --- WhisperX  (only used when AUDIO__PIPELINE=whisperx) ---
# WHISPERX__MODEL=small
# WHISPERX__DEVICE=auto           # auto | cpu | gpu | cuda
# WHISPERX__COMPUTE_TYPE=auto     # auto | int8 | float16 | float32
# WHISPERX__BATCH_SIZE=8
# WHISPERX__LANGUAGE=             # empty = auto-detect
# WHISPERX__DOWNLOAD_ROOT=        # empty = default cache dir
